#include <iostream>
using namespace std;
class Student {
protected:
    int rollNo;
    string name;
public:
    void getStudent() {
        cout << "Enter Roll Number: ";
        cin >> rollNo;
        cout << "Enter Name: ";
        cin >> name;
    }
    void displayStudent() {
        cout << "Roll Number: " << rollNo << endl;
        cout << "Name: " << name << endl;
    }
};
class Result : public Student {
private:
    int m1, m2, m3;
    int total;
    float average;
public:
    void getMarks() {
        getStudent();
        cout << "Enter marks of 3 subjects: ";
        cin >> m1 >> m2 >> m3;
    }
    void calculate() {
        total = m1 + m2 + m3;
        average = total / 3.0;
    }
    void displayResult() {
        displayStudent();
        cout << "Total: " << total << endl;
        cout << "Average: " << average << endl;
    }
};
int main() {
    Result r;
    r.getMarks();
    r.calculate();
    r.displayResult();
    return 0;
}
